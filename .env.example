# myaudi-api — environment template
# Copy to .env (gitignored) and fill in your values.

# --- Audi Connect credentials (required) ---
AUDI_USERNAME=your.email@example.com
AUDI_PASSWORD=your_password
AUDI_COUNTRY=DE
AUDI_API_LEVEL=1

# S-PIN required for lock/unlock and security-pin actions (optional
# but you won't be able to lock/unlock without it).
AUDI_SPIN=1234

# Default VIN — skip --vin on the CLI when you only have one car.
# AUDI_DEFAULT_VIN=WAUXXXXXXXXXXXXX

# --- REST API authentication (required for the FastAPI server) ---
# All endpoints except /health, /ready and /metrics require this
# header: X-API-Key: <value>. Generate a strong key with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
AUDI_API_KEY=change_me_to_a_long_random_string

# --- Webhooks (optional) ---
# If AUDI_WEBHOOK_URL is set, vehicle state changes are POSTed there.
# AUDI_WEBHOOK_URL=https://n8n.example.com/webhook/audi

# If AUDI_WEBHOOK_SECRET is set, outgoing webhooks are signed with
# HMAC-SHA256 in the X-Audi-Signature header.
# AUDI_WEBHOOK_SECRET=change_me_to_a_long_random_string

# --- Background watcher (API server only) ---
# 0 = disabled. Otherwise, minimum 900 (15 min) — Audi rate-limits
# to ~6 req/h, going lower will lock your account.
AUDI_WATCH_INTERVAL=0

# --- Cache (API server only) ---
# Vehicle data cache TTL in seconds. Default 4h. Don't lower below
# 1h without understanding the rate limit implications.
AUDI_CACHE_TTL=14400

# --- Timezone (optional, defaults to Europe/Paris) ---
# TZ=Europe/Brussels
