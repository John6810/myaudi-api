# Audi Connect credentials (used by both CLI and API)
AUDI_USERNAME=your.email@example.com
AUDI_PASSWORD=your_password
AUDI_COUNTRY=DE
AUDI_SPIN=1234
AUDI_API_LEVEL=1

# Default VIN — skip --vin flag for single-vehicle users (optional)
# AUDI_DEFAULT_VIN=WAUXXXXXXXXXXXXX

# Webhook URL — receives POST with state changes (optional)
# AUDI_WEBHOOK_URL=https://n8n.example.com/webhook/audi

# Background watcher interval in seconds (0 = disabled, API server only)
# AUDI_WATCH_INTERVAL=300
